/////////////////////////////////////////////////////
///////////////HOME - BANNER SLIDER /////////////////
/////////////////////////////////////////////////////

.banner-slider
  width: 100%
  height: 90vh
  z-index 2
  @media tablet
    height: 85vh
  @media escritorio-s
    height: 80vh
  @media screen and ( min-height: 920px )
    height: 90vh
.bx-wrapper
  border: initial; /* para eliminar el borde que trae por defecto */
  width: 100% !important
  height: 100% !important /* para ocupar todo el div */

  // Buttons pager inactive
.bx-wrapper .bx-pager.bx-default-pager a 
  background: rgba(255, 255, 255, 0.4)
  transform scale(0.7)
  transition 0.5s

  // Buttons pager - active
.bx-wrapper .bx-pager.bx-default-pager a:hover, .bx-wrapper .bx-pager.bx-default-pager a.active, .bx-wrapper .bx-pager.bx-default-pager a:focus
  background color-white
  transform scale(1)

// Buttons pager - position
.bx-wrapper .bx-pager, .bx-wrapper .bx-controls-auto 
    bottom: 15px !important;
.bx-wrapper .bx-next,.bx-wrapper .bx-prev
  filter: brightness(200%)
// Buttons prev - next Slider
.bx-wrapper .bx-controls-direction a
:root
  --main-color: color-first;

.bxslider
  width: 100% 
  height: 90vh  
  @media tablet
    height: 85vh
  @media escritorio-s
    height: 80vh
  @media screen and ( min-height: 920px )
