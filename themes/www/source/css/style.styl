@import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@900&family=Roboto&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@200;400;500&display=swap');
  
font-xs = 0.8em
font-s = 1.2em
font-m = 1.6em
font-l = 2em
font-xl = 2.8em
font-xxl = 3.5em

fontfamletter = var(--fontfamletter)
fontfamTitles = var(--fontfamTitles)

:root {
  --color-white: #ffffff
  --color-black: #000000
  --color-letter:#706d6d
  --color-first:#4E8BBF
  --color-second: #f16f2d
  --color-third: #f4a46c
  --color-fourth: #8fa4b9
  --color-footer: #F4F4F4
  --fontfamletter : 'Roboto', sans-serif;
  --fontfamTitles : 'Fira Sans', sans-serif
} 

color-white = var(--color-white)
color-black = var(--color-black)
color-letter =var(--color-letter)
color-first = var(--color-first)
color-second = var(--color-second)
color-third = var(--color-third)
color-fourth =var(--color-fourth)
color-footer =var(--color-footer)


movil = 'screen and (min-width: 576px)'
tablet = 'screen and (min-width: 769px)'
escritorio-xs = 'screen and (min-width: 850px)'
escritorio-s = 'screen and (min-width: 992px)'
escritorio-m = 'screen and (min-width: 1200px)'
escritorio-l = 'screen and (min-width: 1400px)'

*
  margin 0px
  padding 0px
  -webkit-box-sizing border-box!important
  -moz-box-sizing border-box!important
  box-sizing border-box!important

vendor(prop, args)
  -webkit-{prop} args
  -moz-{prop} args
  {prop} args

border-radius()
  vendor('border-radius', arguments)

transform()
  vendor('transform', arguments)  

transition()
  vendor('transition', arguments)

//Colores

.color-white
  color color-white
.color-black
  color color-black
.color-letter
  color color-letter
.color-first
  color color-first
.color-second
  color color-second
.color-third
  color color-third
.color-fourth
  color color-fourth
.color-fifth
  color color-fifth

//Letras

.fontfam1
  font-family fontfam1
.fontfam2
  font-family fontfam2

.font-xs
  font-size font-xs
.font-s
  font-size font-s
.font-m
  font-size font-m
.font-l
  font-size font-l
.font-xl
  font-size font-xl
.font-xxl
  font-size font-xxl


//Estilos

