  .slide-item
    position: relative;
    width: 100% 
    height: 100%
    display: block
    img
      width: 100%
      height: 100%
      object-fit: cover

/////////////////////////////////////////////////////
/////////////////HOME - PRODUCTOS ///////////////////
/////////////////////////////////////////////////////

.product  /* product section */
  width: 100%
  height: 100%
  display: flex
  flex-direction: column
  justify-content: center
  align-items: center
  padding: 120px 20px 50px

  .product_title
    width: 100%
    text-align: left
    h2
      color color-first
      font-family: fontfamTitles
      font-size: font-xl

  .product-container   /* product gallery */
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    column-gap: 1.5rem;
    row-gap: 1.5rem;
    width 100%
    padding: 20px 0px

    @media (min-width: 600px) 
      grid-template-columns: repeat(2, 1fr);
      

    .right-card
      flex-direction: reverse
      @media (min-width: 600px) 
        flex-direction: row-reverse

      .card__triangle
        transform rotate(360deg)
        @media (min-width: 600px) 
          transform rotate(180deg)

    .first-color
      .card__triangle
        border-left: 25px solid color-first !important;
      .card__icon
        background: color-first !important
      .card__text 
        background: color-first !important

    .card /* product card */
      display: flex
      width 100%;
      height: 120px
      position: relative
      z-index 2
      .card__icon
        padding: 10px 15px
        min-width: 110px 
        max-width: 110px 
        height: 100%
        background: color-second
        display: flex
        justify-content: center
        align-items: center
        flex-direction: column
        position: relative
        img
          padding: 10px 5px 0px
          width: 100%
          height: auto
        .title
          text-align: center
          color color-white
          font-size: font-xs
          width: 100%
          padding: 5px 0px 0px
          height: auto
          text-transform uppercase
          
      .card__text 
        width: 0%
        flex-direction: column
        background: color-second
        color color-white
        font-family: fontfamletter
        display -webkit-box
        -webkit-line-clamp 5
        line-height  1.4
        -webkit-box-orient vertical
        overflow hidden
        text-overflow ellipsis
        transition width 1s
        transition 1s
        padding: 8px 0px

        h2
          font-size: font-s
        p 
          opacity: 0
          font-size: font-xs
          transition: 2s

      .card__triangle
        width: 25px
        height: 100%
        display: block
        border-left: 25px solid color-second;
        border-top: 60px solid transparent;
        border-bottom: 60px solid transparent; 

      .card__image
        position: absolute
        top 50%
        left: 50%
        transform translate(-50%,-50%)
        width: 100%
        height: 100%
        z-index: -1
        img
          width: 100%
          height: 100%
          object-fit: cover

    .card:hover .card__text 
      width 60%
      padding: 8px 10px
      p
        opacity: 1


/////////////////////////////////////////////////////
///////////////HOME - BRAND SLIDER /////////////////
/////////////////////////////////////////////////////

animationSpeed = var(--times) ;

.banner-brand-slider
  width: 100%
  height: 100%
  padding: 50px 0px

// Animation full screen
@keyframes scroll 
	0% { transform: translateX(0); }
	100% { transform: translateX(calc(-250px * var(--cant)))}
// Animation media tablet
@keyframes scrollm 
	0% { transform: translateX(0); }
	100% { transform: translateX(calc(-190px *  var(--cant)))}


// Styling
.slider-brands
	background white
	height 100px
	margin auto
	overflow:hidden
	position: relative
	max-width 960px
  display: flex
  justify-content: center
  align-items: center
	
	&::before,
	&::after 
		background: linear-gradient(to right,  rgba(255,255,255,1) 0%,rgba(255,255,255,0) 100%);
		content: "";
		height: 100px;
		position: absolute;
		width: 100px;
		z-index: 2;
	
	
	&::after 
		right: 0;
		top: 0;
		transform: rotateZ(180deg);
	

	&::before 
		left: 0;
		top: 0;
	
	
	.slide-track 
		animation: scrollm animationSpeed linear infinite;
		display: flex;
		width: calc(190px * 2 * var(--cant));
	
	
	.slide 
		height: 80px;
		width: 190px;
  .image
    width: 100%
    height: 100%
    object-fit: cover
    margin auto

.slider-brands
  display: flex
  align-items:  center
  @media tablet
    max-width: 960px
    &::before,
	  &::after 
      width: 200px;
    .slide-track 
      animation: scroll animationSpeed linear infinite;
      width: calc(250px * 2 * var(--cant));
    .slide 
      height: 100px;
      width: 250px;

